generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Naming Convention
// - Prisma model name: PascalCase (서비스 코드에서 사용)
// - DB table name: snake_case (@@map으로 매핑)
// - DB column name: snake_case (@map은 camelCase 컬럼에만 추가, 이미 snake_case인 컬럼은 생략)
// - Prisma field name: camelCase (TypeScript 관례)
// ---------------------------------------------------------------------------

/// 사용자 계정 정보
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  nickname  String   @unique
  avatar    String?
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  messages     Message[]
  chatRooms    ChatRoomMember[]
  readReceipts ReadReceipt[]

  @@map("account_info")
}

/// 채팅방 (1:1 또는 그룹)
model ChatRoom {
  id        String   @id @default(uuid())
  name      String?
  type      RoomType @default(DIRECT)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members  ChatRoomMember[]
  messages Message[]

  @@map("chat_room")
}

/// 채팅방 참여 멤버 (다대다 조인 테이블)
model ChatRoomMember {
  id       String   @id @default(uuid())
  userId   String   @map("user_id")
  roomId   String   @map("room_id")
  joinedAt DateTime @default(now()) @map("joined_at")

  user User     @relation(fields: [userId], references: [id])
  room ChatRoom @relation(fields: [roomId], references: [id])

  @@unique([userId, roomId])
  @@map("chat_room_member")
}

/// 채팅 메시지
model Message {
  id        String      @id @default(uuid())
  content   String
  type      MessageType @default(TEXT)
  fileUrl   String?     @map("file_url")
  userId    String      @map("user_id")
  roomId    String      @map("room_id")
  createdAt DateTime    @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id])
  room         ChatRoom      @relation(fields: [roomId], references: [id])
  readReceipts ReadReceipt[]

  @@index([roomId, createdAt])
  @@map("message")
}

/// 메시지 읽음 확인 기록
model ReadReceipt {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  messageId String   @map("message_id")
  readAt    DateTime @default(now()) @map("read_at")

  user    User    @relation(fields: [userId], references: [id])
  message Message @relation(fields: [messageId], references: [id])

  @@unique([userId, messageId])
  @@index([messageId])
  @@map("read_receipt")
}

/// 채팅방 유형
enum RoomType {
  DIRECT
  GROUP

  @@map("room_type")
}

/// 메시지 유형
enum MessageType {
  TEXT
  IMAGE
  FILE

  @@map("message_type")
}
