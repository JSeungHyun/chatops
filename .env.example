# ChatOps Environment Variables
# Copy this file to .env and update values for your environment.

DATABASE_URL=postgresql://chatops:change-me@postgres:5432/chatops
REDIS_HOST=redis
REDIS_PORT=6379
RABBITMQ_URL=amqp://guest:change-me@rabbitmq:5672
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=chatops-files
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
PORT=3000
NODE_ENV=production
